# Oscar-Next Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────────────────────
# Existing Oscar MariaDB — schema is read-only (no migrations touch existing tables)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=oscar
DB_USER=oscar
DB_PASSWORD=j0UkT2EKDFQ=
# Async SQLAlchemy connection URL (built from above — do not edit)
# DATABASE_URL=mysql+aiomysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Auth — Keycloak ───────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=oscar
KEYCLOAK_CLIENT_ID=oscar-api
KEYCLOAK_CLIENT_SECRET=changeme
# Public key URL for JWT RS256 validation (auto-discovered from Keycloak)
# JWKS_URL=${KEYCLOAK_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
LOG_LEVEL=INFO

# ── FHIR ──────────────────────────────────────────────────────────────────────
FHIR_BASE_URL=http://localhost:8000/fhir/R4

# ── External Services ─────────────────────────────────────────────────────────
DRUGREF2_URL=http://drugref2-api:8080
AI_SIDECAR_URL=http://oscar-ai:8001

# ── Admin UI config endpoint ──────────────────────────────────────────────────
# When true, the /admin/config endpoint allows reading/writing .env values
# Only enable behind admin role authentication
ADMIN_CONFIG_ENABLED=true
CLOUDFLARE_TUNNEL_TOKEN=eyJhI...   ← paste token here
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
KEYCLOAK_PUBLIC_HOST=auth.yourdomain.com