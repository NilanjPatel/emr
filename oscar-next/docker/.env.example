# Oscar-Next Docker services — copy to .env and fill in values
# NEVER commit .env to git

# ── Database (Oscar MariaDB — shared, read credentials only) ──────────────────
DB_PASSWORD=your-oscar-db-password

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD=choose-a-strong-password
KEYCLOAK_ADMIN_PASSWORD=choose-a-strong-password
KEYCLOAK_CLIENT_SECRET=oscar-api-client-secret     # machine-to-machine client
KEYCLOAK_WEB_CLIENT_SECRET=                        # oscar-web is public client — leave blank

# Keycloak public hostname (used in tokens — must match what browser sees)
KEYCLOAK_PUBLIC_HOST=auth.yourdomain.com            # e.g. auth.clinic.ca
KEYCLOAK_PUBLIC_PORT=443                            # 443 when behind Cloudflare

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production                                  # development | production
LOG_LEVEL=INFO

# ── Domains (Cloudflare DNS entries) ─────────────────────────────────────────
APP_DOMAIN=app.yourdomain.com                       # Next.js frontend
API_DOMAIN=api.yourdomain.com                       # FastAPI backend

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get from: Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create tunnel
# After creating tunnel, configure routes in the dashboard:
#   app.<domain>  → http://oscar-web:3000
#   api.<domain>  → http://oscar-api:8000
#   auth.<domain> → http://keycloak:8080
CLOUDFLARE_TUNNEL_TOKEN=paste-your-tunnel-token-here

# ── AI Sidecar (Phase 3+) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                                  # fill when AI sidecar activates
OLLAMA_HOST=http://ollama:11434                     # on-premise LLM host
